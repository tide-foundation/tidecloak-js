{
  "name": "@tidecloak/js",
  "version": "0.13.31",
  "description": "Vanilla JavaScript/browser SDK for TideCloak with an IAMService singleton and low-level client.",
  "type": "module",
  "main": "dist/cjs/src/index.js",
  "module": "dist/esm/src/index.js",
  "types": "dist/types/src/index.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/src/index.d.ts",
      "import": "./dist/esm/src/index.js",
      "require": "./dist/cjs/src/index.js",
      "default": "./dist/esm/src/index.js"
    },
    "./policy-react": {
      "types": "./dist/types/src/policy-react.d.ts",
      "import": "./dist/esm/src/policy-react.js",
      "require": "./dist/cjs/src/policy-react.js"
    },
    "./policy.css": "./dist/esm/src/policy.css"
  },
  "scripts": {
    "postinstall": "node ./scripts/postinstall.cjs",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:types": "tsc -p tsconfig.types.json",
    "build:copy-css": "node scripts/copy-css.cjs",
    "build": "npm run build:cjs && npm run build:esm && npm run build:types && npm run build:copy-css && cp ./silent-check-sso.html dist/ && node scripts/postbuild.cjs",
    "prepare": "npm run build"
  },
  "files": [
    "dist",
    "scripts/postinstall.cjs",
    "silent-check-sso.html"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tide-foundation/tidecloak-js.git"
  },
  "author": "Tide",
  "license": "https://tide.org/licenses_tcoc2-0-0-en",
  "keywords": [
    "security",
    "tidecloak",
    "tide",
    "authentication",
    "oidc",
    "oauth2",
    "authorization"
  ],
  "dependencies": {
    "heimdall-tide": "^0.13.31",
    "@tideorg/js": "^0.13.31"
  },
  "peerDependencies": {
    "@tidecloak/policy": "^0.13.31"
  },
  "peerDependenciesMeta": {
    "@tidecloak/policy": {
      "optional": true
    }
  }
}
